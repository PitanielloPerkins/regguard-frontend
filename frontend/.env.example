# Copy to ``frontend/.env`` and adjust. Values prefixed VITE_ are exposed to the browser bundle.

# Public FastAPI origin (baked into the bundle at build time). Omit for local dev (127.0.0.1:8000).
# VITE_BACKEND_ORIGIN=https://your-api.example.com

# Google Maps (Places autocomplete)
# VITE_GOOGLE_MAPS_API_KEY=
