# Ignore Python backend - deploy separately to Render
backend/
api/
*.py
requirements.txt
venv/
__pycache__/
*.pyc

# Ignore documentation
README.md
*.md

# Ignore build outputs and caches
# NOTE: Do NOT ignore frontend/dist - Vercel builds it!
frontend/node_modules
backend/node_modules
backend/venv
backend/__pycache__
backend/.pytest_cache
.pytest_cache

# Ignore version control and config
.git
.github
.gitignore
.cursor
.env
.env.example
.vercel

# Ignore logs and system files
*.log
.DS_Store
node_modules
