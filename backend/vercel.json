{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "runtime": "python3.10",
  "functions": {
    "main.py": {
      "runtime": "python3.10",
      "maxDuration": 30
    }
  },
  "env": {
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "FIRECRAWL_API_KEY": "@firecrawl_api_key",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "QUEUE_TEST_MODE": "false"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/main.py"
    }
  ]
}
