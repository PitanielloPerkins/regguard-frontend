# Reg Guard — backend environment template
# Copy this file to .env and fill in your actual API keys
# DO NOT COMMIT .env file; only commit this .env.example

# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_RESEARCH_MODEL=claude-3-5-haiku-latest

# Payments
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Firecrawl — web search / scraping engine
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Data
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Vision & Maps
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-1.5-pro
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Service (Free Trial) — Choose one: SendGrid OR Resend
# SendGrid Option
SENDGRID_API_KEY=your_sendgrid_api_key_here

# OR Resend Option (if using Resend instead of SendGrid)
RESEND_API_KEY=your_resend_api_key_here

# CORS & Origin Configuration
REG_GUARD_EXTRA_CORS_ORIGINS=https://app.regguardagent.com,https://regguardagent.com

